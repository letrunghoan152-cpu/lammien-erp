# ─── Cấu hình kết nối GAS + Google OAuth ───────────────────────────────────────
# Copy file này thành `.env.local` rồi điền giá trị thật.

# URL Web App của Google Apps Script (Deploy → New deployment → Web app)
#   Execute as: Me   |   Who has access: Anyone
NEXT_PUBLIC_GAS_URL=https://script.google.com/macros/s/XXXXXXXXXXXX/exec

# Google OAuth Client ID (Google Cloud Console → Credentials → OAuth client ID → Web)
#   Authorized JavaScript origins phải gồm: http://localhost:3000 và domain production
NEXT_PUBLIC_GOOGLE_CLIENT_ID=XXXXXXXXXXXX.apps.googleusercontent.com
